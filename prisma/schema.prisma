// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//  binaryTargets = ["debian-openssl-1.1.x"]

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  passwordHash           String
  name                   String
  nameAm                 String?
  role                   Role
  salary                 Decimal?
  hireDate               DateTime
  releaseDate            DateTime?
  isActive               Boolean                 @default(true)
  phone                  String?
  orders                 Order[]
  notificationPreference NotificationPreference?
  salaryHistory          SalaryHistory[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model SalaryHistory {
  id        String   @id @default(uuid())
  userId    String
  salary    Decimal
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum Station {
  BAR
  KITCHEN
}

model MenuItem {
  id          String               @id @default(uuid())
  name        String
  nameAm      String?
  price       Decimal
  category    String
  categoryAm  String?
  station     Station              @default(BAR)
  imageUrl    String?
  isActive    Boolean              @default(true)
  ingredients MenuItemIngredient[]
  orderItems  OrderItem[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model Ingredient {
  id               String               @id @default(uuid())
  nameAm           String?
  name             String
  unit             String
  currentStock     Decimal
  minThreshold     Decimal
  menuItems        MenuItemIngredient[]
  stockAdjustments StockAdjustment[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model MenuItemIngredient {
  id                 String     @id @default(uuid())
  menuItemId         String
  ingredientId       String
  quantityPerServing Decimal
  menuItem           MenuItem   @relation(fields: [menuItemId], references: [id])
  ingredient         Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([menuItemId, ingredientId])
}

model StockAdjustment {
  id           String     @id @default(uuid())
  ingredientId String
  quantity     Decimal
  reason       String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  createdAt    DateTime   @default(now())
}

model Order {
  id          String       @id @default(uuid())
  waiterId    String
  waiter      User         @relation(fields: [waiterId], references: [id])
  tableNumber String?
  dailyOrderNumber Int     @default(0)
  status      OrderStatus  @default(PENDING)
  paymentType PaymentType?
  receiptUrl  String?
  total       Decimal
  items       OrderItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  paidAt      DateTime?
}

enum OrderStatus {
  PENDING
  PENDING_VERIFICATION
  PAID
  CANCELLED
}

enum PaymentType {
  CASH
  DIGITAL
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Decimal
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model NotificationPreference {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  lowStock        Boolean  @default(true)
  largeOrders     Boolean  @default(true)
  employeeActions Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
